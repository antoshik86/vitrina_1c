// Модуль формы внешней обработки "ВыгрузкаВитриныНаХостинг"

&НаКлиенте
Процедура Выгрузить(Команда)

    // Проверка заполнения
    Если ПустаяСтрока(Объект.Сервер) Или ПустаяСтрока(Объект.Пользователь) Тогда
        ПоказатьПредупреждение(, "Заполните настройки FTP (Сервер, Пользователь, Пароль)");
        Возврат;
    КонецЕсли;

    // Подтверждение
    Ответ = Вопрос("Выгрузить " + Строка(Объект.ПутьНаСервере) + " на " + Объект.Сервер + "?",
                    РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);
    Если Ответ <> КодВозвратаДиалога.Да Тогда
        Возврат;
    КонецЕсли;

    // Вызов сервера
    Оповещение = Новый ОписаниеОповещения("ПослеВыгрузки", ЭтотОбъект);
    ВыгрузитьНаСервере(Оповещение, Объект.Сервер, Объект.Порт,
                        Объект.Пользователь, Объект.Пароль, Объект.ПутьНаСервере);

КонецПроцедуры

&НаКлиенте
Процедура ПослеВыгрузки(Результат, ДополнительныеПараметры) Экспорт
    Если Результат = Неопределено Тогда
        ПоказатьПредупреждение(, "Выгрузка завершена!");
    Иначе
        ПоказатьПредупреждение(, "Ошибка: " + Результат.Описание);
    КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ВыгрузитьНаСервере(Оповещение, Сервер, Порт, Пользователь, Пароль, ПутьНаСервере)

    Обработка = РеквизитФормыВЗначение("Объект");

    Попытка
        Обработка.ВыгрузитьНаХостинг(Сервер, Порт, Пользователь, Пароль, ПутьНаСервере);
        ВыполнитьОбработкуОповещения(Оповещение, Неопределено);
    Исключение
        ВыполнитьОбработкуОповещения(Оповещение, ИнформацияОбОшибке());
    КонецПопытки;

КонецПроцедуры

&НаСервере
