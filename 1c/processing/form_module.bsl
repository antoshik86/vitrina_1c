// Модуль формы внешней обработки "ВыгрузкаВитриныНаХостинг"
// Форма строится полностью программно в ПриСозданииНаСервере

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    // Значения по умолчанию
    Объект.Сервер = "77.222.40.200";
    Объект.Порт = 21;
    Объект.Пользователь = "antonilyas";
    Объект.ПутьНаСервере = "/public_html";

    // Строим форму программно
    ПостроитьФорму();

КонецПроцедуры

&НаСервере
Процедура ПостроитьФорму()

    // Заголовок
    Элемент = Элементы.Добавить("ДекорацияЗаголовок", Тип("ПолеФормы"), Элементы.ОсновнаяГруппа);
    Элемент.Вид = ВидПоляФормы.ПолеНадписи;
    Элемент.Заголовок = "Выгрузка каталога товаров на сайт витрины";
    Элемент.РастягиватьПоГоризонтали = Истина;
    Элемент.Высота = 3;

    // Группа FTP
    Группа = Элементы.Добавить("ГруппаFTP", Тип("ГруппаФормы"), Элементы.ОсновнаяГруппа);
    Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
    Группа.Отображение = ОтображениеОбычнойГруппы.СлабоеВыделение;
    Группа.Заголовок = "Настройки FTP";
    Группа.РастягиватьПоГоризонтали = Истина;

    // Поле Сервер
    Элемент = Элементы.Добавить("ПолеСервер", Тип("ПолеФормы"), Группа);
    Элемент.Вид = ВидПоляФормы.ПолеВвода;
    Элемент.Заголовок = "Сервер";
    Элемент.ПутьКДанным = "Объект.Сервер";

    // Поле Порт
    Элемент = Элементы.Добавить("ПолеПорт", Тип("ПолеФормы"), Группа);
    Элемент.Вид = ВидПоляФормы.ПолеВвода;
    Элемент.Заголовок = "Порт";
    Элемент.ПутьКДанным = "Объект.Порт";
    Элемент.Ширина = 8;

    // Поле Пользователь
    Элемент = Элементы.Добавить("ПолеПользователь", Тип("ПолеФормы"), Группа);
    Элемент.Вид = ВидПоляФормы.ПолеВвода;
    Элемент.Заголовок = "Пользователь";
    Элемент.ПутьКДанным = "Объект.Пользователь";

    // Поле Пароль
    Элемент = Элементы.Добавить("ПолеПароль", Тип("ПолеФормы"), Группа);
    Элемент.Вид = ВидПоляФормы.ПолеВвода;
    Элемент.Заголовок = "Пароль";
    Элемент.ПутьКДанным = "Объект.Пароль";
    Элемент.РежимПароля = Истина;

    // Поле ПутьНаСервере
    Элемент = Элементы.Добавить("ПолеПуть", Тип("ПолеФормы"), Группа);
    Элемент.Вид = ВидПоляФормы.ПолеВвода;
    Элемент.Заголовок = "Путь на сервере";
    Элемент.ПутьКДанным = "Объект.ПутьНаСервере";

    // Разделитель
    Элемент = Элементы.Добавить("Разделитель", Тип("ГруппаФормы"), Элементы.ОсновнаяГруппа);
    Элемент.Вид = ВидГруппыФормы.ОбычнаяГруппа;
    Элемент.Отображение = ОтображениеОбычнойГруппы.Нет;
    Элемент.ОтображатьЗаголовок = Ложь;
    Элемент.Высота = 1;

    // Команда
    Команда = Команды.Добавить("Выгрузить");
    Команда.Заголовок = "Выгрузить каталог на хостинг";
    Команда.Действие = "Выгрузить";

    // Кнопка
    Элемент = Элементы.Добавить("КнопкаВыгрузить", Тип("ПолеФормы"), Элементы.ОсновнаяГруппа);
    Элемент.Вид = ВидПоляФормы.КнопкаФормы;
    Элемент.Заголовок = "Выгрузить каталог на хостинг";
    Элемент.ИмяКоманды = "Выгрузить";
    Элемент.РастягиватьПоГоризонтали = Истина;

КонецПроцедуры

&НаКлиенте
Процедура Выгрузить(Команда)

    Если ПустаяСтрока(Объект.Сервер) Или ПустаяСтрока(Объект.Пользователь) Тогда
        ПоказатьПредупреждение(, "Заполните настройки FTP");
        Возврат;
    КонецЕсли;

    Ответ = Вопрос("Выгрузить на сервер " + Объект.Сервер + "?",
                    РежимДиалогаВопрос.ДаНет);
    Если Ответ <> КодВозвратаДиалога.Да Тогда
        Возврат;
    КонецЕсли;

    ВыгрузитьНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьНаСервере()

    Параметры = Новый Структура;
    Параметры.Вставить("Сервер", Объект.Сервер);
    Параметры.Вставить("Порт", Объект.Порт);
    Параметры.Вставить("Пользователь", Объект.Пользователь);
    Параметры.Вставить("Пароль", Объект.Пароль);
    Параметры.Вставить("ПутьНаСервере", Объект.ПутьНаСервере);

    Обработка = РеквизитФормыВЗначение("Объект");

    Попытка
        Обработка.ВыгрузитьНаХостинг(
            Параметры.Сервер,
            Параметры.Порт,
            Параметры.Пользователь,
            Параметры.Пароль,
            Параметры.ПутьНаСервере);
        ПоказатьПредупреждение(, "Выгрузка завершена!");
    Исключение
        ПоказатьПредупреждение(, "Ошибка: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры
