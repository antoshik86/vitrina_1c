// Внешняя обработка "HTTP-сервис витрины"
// Подключается к опубликованному HTTP-сервису "vitrina"
// Или можно реализовать как модуль соответствующего HTTP-сервиса в конфигурации

Функция ОбработкаGET(Запрос)

    Путь = Запрос.Параметры["Путь"];

    Если Путь = "catalog" Тогда
        Возврат ОтветJSON(ПолучитьКаталог());
    ИначеЕсли Путь НачинаетсяС "product/" Тогда
        Ид = Сред(Путь, 9);
        Возврат ОтветJSON(ПолучитьТовар(Ид));
    ИначеЕсли Путь = "chat/messages" Тогда
        Возврат ОтветJSON(ПолучитьСообщенияЧата());
    Иначе
        Возврат Ответ404();
    КонецЕсли;

КонецФункции

Функция ОбработкаPOST(Запрос)

    Путь = Запрос.Параметры["Путь"];
    Тело = ПрочитатьJSON(Запрос.ПолучитьТелоКакСтроку());

    Если Путь = "order" Тогда
        Возврат ОтветJSON(СоздатьЗаказ(Тело));
    ИначеЕсли Путь = "chat/ai" Тогда
        Возврат ОтветJSON(СпроситьAI(Тело));
    ИначеЕсли Путь = "chat/message" Тогда
        Возврат ОтветJSON(ОтправитьСообщениеМенеджеру(Тело));
    Иначе
        Возврат Ответ404();
    КонецЕсли;

КонецФункции

Функция ОбработкаOPTIONS(Запрос)
    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
    Ответ.Заголовки.Вставить("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    Ответ.Заголовки.Вставить("Access-Control-Allow-Headers", "Content-Type, Authorization");
    Возврат Ответ;
КонецФункции

Функция ОтветJSON(Данные)
    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=UTF-8");
    Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
    Ответ.УстановитьТелоИзСтроки(JSON(Данные));
    Возврат Ответ;
КонецФункции

Функция Ответ404()
    Ответ = Новый HTTPСервисОтвет(404);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=UTF-8");
    Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
    Ответ.УстановитьТелоИзСтроки(JSON(Новый Структура("error", "Not found")));
    Возврат Ответ;
КонецФункции

Функция ПрочитатьJSON(Строка)
    Чтение = Новый ЧтениеJSON;
    Чтение.УстановитьСтроку(Строка);
    Результат = ПрочитатьJSON(Чтение);
    Чтение.Закрыть();
    Возврат Результат;
КонецФункции

Функция JSON(Значение)
    Запись = Новый ЗаписьJSON;
    Стр = "";
    Запись.УстановитьСтроку(Стр);
    ЗаписатьJSON(Запись, Значение);
    Запись.Закрыть();
    Возврат Стр;
КонецФункции

