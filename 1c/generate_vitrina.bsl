// 1C-скрипт: Внешняя обработка "Генератор витрины"
// Запускается из 1С:Предприятие (УНФ), формирует статические HTML-файлы
// для загрузки на хостинг

Процедура СформироватьВитрину(Команда)

    Путь = ПараметрыОбработки.ПутьПубликации; // Каталог на диске

    // 1. Формируем JSON для каталога
    КаталогТоваров = ПолучитьКаталогТоваров(); // Возвращает массив структур
    Категории = ПолучитьКатегории();

    ДанныеКаталога = Новый Структура;
    ДанныеКаталога.Вставить("products", КаталогТоваров);
    ДанныеКаталога.Вставить("categories", Категории);

    // Сохраняем JSON для подгрузки через API (или для генерации)
    ЗаписатьТекст(Путь + "/data/catalog.json", JSON(ДанныеКаталога));

    // 2. Генерируем HTML-карточки товаров (для SEO)
    Для Каждого Товар Из КаталогТоваров Цикл
        СгенерироватьКарточку(Товар, Путь);
    КонецЦикла;

    Сообщить("Витрина сгенерирована: " + Путь);

КонецПроцедуры

Процедура СгенерироватьКарточку(Товар, Путь)

    HTML = Новый ТекстовыйДокумент;
    HTML.ДобавитьСтроку("<!DOCTYPE html>");
    HTML.ДобавитьСтроку("<html lang='ru'>");
    HTML.ДобавитьСтроку("<head>");
    HTML.ДобавитьСтроку("<meta charset='UTF-8'>");
    HTML.ДобавитьСтроку("<title>" + Товар.Наименование + " | Каталог</title>");
    HTML.ДобавитьСтроку("<link rel='stylesheet' href='/css/style.css'>");
    HTML.ДобавитьСтроку("</head>");
    HTML.ДобавитьСтроку("<body>");
    // ... сгенерировать полную HTML-карточку товара
    HTML.ДобавитьСтроку("</body>");
    HTML.ДобавитьСтроку("</html>");

    ИмяФайла = Путь + "/product/" + Товар.Ид + ".html";
    HTML.Записать(ИмяФайла);

КонецПроцедуры

// ======= Вспомогательные функции =======

Функция ПолучитьКаталогТоваров()

    Результат = Новый Массив;
    Запрос = Новый Запрос("
    |ВЫБРАТЬ
    |   Номенклатура.Ссылка КАК Ид,
    |   Номенклатура.Наименование КАК Наименование,
    |   Номенклатура.Артикул КАК Артикул,
    |   Номенклатура.ЦенаПродажи КАК Цена,
    |   Номенклатура.ВидНоменклатуры.Наименование КАК Категория
    |ИЗ
    |   Справочник.Номенклатура КАК Номенклатура
    |ГДЕ
    |   Номенклатура.НеУдалять = Ложь
    |   И Номенклатура.ПометкаУдаления = Ложь
    |   И Номенклатура.ЭтоГруппа = Ложь");

    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Товар = Новый Структура;
        Товар.Вставить("id", Строка(Выборка.Ид.УникальныйИдентификатор()));
        Товар.Вставить("name", Выборка.Наименование);
        Товар.Вставить("article", Выборка.Артикул);
        Товар.Вставить("price", Выборка.Цена);
        Товар.Вставить("category", Выборка.Категория);
        // Товар.Вставить("image", ПолучитьСсылкуНаКартинку(Выборка.Ид));
        Результат.Добавить(Товар);
    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция ПолучитьКатегории()

    Результат = Новый Массив;
    Запрос = Новый Запрос("
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |   Номенклатура.ВидНоменклатуры.Наименование КАК Наименование
    |ИЗ
    |   Справочник.Номенклатура КАК Номенклатура
    |ГДЕ
    |   Номенклатура.ВидНоменклатуры.Наименование > """"
    |   И Номенклатура.НеУдалять = Ложь");
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Категория = Новый Структура;
        Категория.Вставить("id", Выборка.Наименование);
        Категория.Вставить("name", Выборка.Наименование);
        Результат.Добавить(Категория);
    КонецЦикла;
    Возврат Результат;

КонецФункции

Процедура ЗаписатьТекст(ИмяФайла, Текст)

    ТекстовыйДокумент = Новый ТекстовыйДокумент;
    ТекстовыйДокумент.УстановитьТекст(Текст);
    ТекстовыйДокумент.Записать(ИмяФайла);

КонецПроцедуры

Функция JSON(Значение)
    // Использует стандартный механизм 1С
    ЗаписьJSON = Новый ЗаписьJSON;
    СтрокаJSON = "";
    ЗаписьJSON.УстановитьСтроку(СтрокаJSON);
    ЗаписатьJSON(ЗаписьJSON, Значение);
    ЗаписьJSON.Закрыть();
    Возврат СтрокаJSON;
КонецФункции
