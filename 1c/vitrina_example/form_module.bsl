// Модуль формы внешней обработки "ВыгрузкаВитриныНаХостинг_DFI"
// Форма создаётся автоматически через DFI при открытии

// ===== ЭКСПОРТНЫЕ ПРОЦЕДУРЫ ДЛЯ DFI =====

&НаСервере
Процедура СоздатьФормуЧерезDFI(Форма) Экспорт
    // Родитель — сама форма
    Родитель = Форма.Элементы;

    // Заголовок
    ДФИ.СздПоле(Форма, "Заголовок", Родитель, "Выгрузка каталога товаров на сайт витрины", 0, "",
        Новый Структура("Вид, Заголовок, РастягиватьПоГоризонтали, Высота",
            ВидПоляФормы.ПолеНадписи, "Выгрузка каталога товаров на сайт витрины", ИСТИНА, 3));

    // Группа настроек FTP
    ГруппаFTP = ДФИ.СздГруппаОбычная(Форма, "ГруппаFTP", Родитель, "Настройки FTP", 1, 1, 0);

    // Поле Сервер
    ДФИ.СздПоле(Форма, "Сервер", ГруппаFTP, "Сервер", 1, "Объект.Сервер");
    // Поле Порт
    ДФИ.СздПоле(Форма, "Порт", ГруппаFTP, "Порт", 1, "Объект.Порт",
        Новый Структура("Ширина", 8));
    // Поле Пользователь
    ДФИ.СздПоле(Форма, "Пользователь", ГруппаFTP, "Пользователь", 1, "Объект.Пользователь");
    // Поле Пароль (с режимом пароля)
    ДФИ.СздПоле(Форма, "Пароль", ГруппаFTP, "Пароль", 1, "Объект.Пароль",
        Новый Структура("РежимПароля", ИСТИНА));
    // Поле ПутьНаСервере
    ДФИ.СздПоле(Форма, "ПутьНаСервере", ГруппаFTP, "Путь на сервере", 1, "Объект.ПутьНаСервере");

    // Разделитель
    ДФИ.СздГруппаОбычнаяБезОтображения(Форма, "Разделитель", Родитель, 0, 0, 0,
        Новый Структура("Высота", 1));

    // Команда
    ДФИ.СоздатьКоманду(Форма, "Выгрузить", "Выгрузить каталог на хостинг", "Выгрузить");
    // Кнопка
    Кнопка = ДФИ.СздПоле(Форма, "КнопкаВыгрузить", Родитель, "", 0, "",
        Новый Структура("Вид, Заголовок, ИмяКоманды, РастягиватьПоГоризонтали",
            ВидПоляФормы.КнопкаФормы, "Выгрузить каталог на хостинг", "Выгрузить", ИСТИНА));
КонецПроцедуры

// ===== ОБРАБОТЧИКИ ФОРМЫ =====

&НаКлиенте
Процедура Выгрузить(Команда)
    Если ПустаяСтрока(Объект.Сервер) Или ПустаяСтрока(Объект.Пользователь) Тогда
        ПоказатьПредупреждение(, "Заполните настройки FTP (Сервер, Пользователь, Пароль)");
        Возврат;
    КонецЕсли;

    Ответ = Вопрос("Выгрузить " + Строка(Объект.ПутьНаСервере) + " на " + Объект.Сервер + "?",
                    РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);
    Если Ответ <> КодВозвратаДиалога.Да Тогда Возврат КонецЕсли;

    Оповещение = Новый ОписаниеОповещения("ПослеВыгрузки", ЭтотОбъект);
    ВыгрузитьНаСервере(Оповещение, Объект.Сервер, Объект.Порт,
                        Объект.Пользователь, Объект.Пароль, Объект.ПутьНаСервере);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыгрузки(Результат, ДополнительныеПараметры) Экспорт
    Если Результат = Неопределено Тогда
        ПоказатьПредупреждение(, "Выгрузка завершена!");
    Иначе
        ПоказатьПредупреждение(, "Ошибка: " + Результат.Описание);
    КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ВыгрузитьНаСервере(Оповещение, Сервер, Порт, Пользователь, Пароль, ПутьНаСервере)
    Обработка = РеквизитФормыВЗначение("Объект");
    Попытка
        Обработка.ВыгрузитьНаХостинг(Сервер, Порт, Пользователь, Пароль, ПутьНаСервере);
        ВыполнитьОбработкуОповещения(Оповещение, Неопределено);
    Исключение
        ВыполнитьОбработкуОповещения(Оповещение, ИнформацияОбОшибке());
    КонецПопытки;
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    // Значения по умолчанию
    Объект.Сервер = "77.222.40.200";
    Объект.Порт = 21;
    Объект.Пользователь = "antonilyas";
    Объект.ПутьНаСервере = "/public_html";

    // Создаём форму через DFI (Форма — встроенная переменная формы)
    СоздатьФормуЧерезDFI(Форма);
КонецПроцедуры
