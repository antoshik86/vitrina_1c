&процедура(Имя) Экспорт
#Область DFI_ВспомогательныеФункции
Функция ОчиститьОтЗапрещенныхСимволов(Знач Текст, ДопСимволы = "")
	ЗапрещенныеСимволы = "\,/,:,*,?,"",<,>,|" + ДопСимволы++;
	Для Сч = 1 По СтрДлина(Текст) Цикл
		Симв = Сред(Текст, Сч, 1);
		Если СтрНайти(ЗапрещенныеСимволы, Симв) > 0 Тогда
			Продолжить;
		КонецЕсли;
		Рез = Рез + Симв;
	КонецЦикла;
	Возврат Рез;
КонецФункции

Функция ЕслиСтруктураНеопределеноТоНовая(Знач Структура)
	Если ТипЗнч(Структура) = Тип("Структура") Тогда
		Возврат Структура;
	Иначе
		Возврат Новый Структура;
	КонецЕсли;
КонецФункции

Функция ОпределитьЭлементФормы(Форма, Имя, ИмяРодителя = "")
	Элемент = Форма.Элементы.Найти(Имя);
	Если Элемент = Неопределено Тогда
		Элемент = Неопределено;
	КонецЕсли;
	Возврат Элемент;
КонецФункции

Функция ПолучитьСостояниеРастягиванияЭлементаПоГоризонтали(ГоризонтальноеРастягивание)
	Если ГоризонтальноеРастягивание = "Нет" Тогда
		Возврат ИспользованиеГоризонтальногоРастягивания.НеИспользовать;
	ИначеЕсли ГоризонтальноеРастягивание = "Использовать" Тогда
		Возврат ИспользованиеГоризонтальногоРастягивания.Использовать;
	Иначе
		Возврат ИспользованиеГоризонтальногоРастягивания.Доступно;
	КонецЕсли;
КонецФункции

Функция ПолучитьСостояниеРастягиванияЭлементаПоВертикали(ВертикальноеРастягивание)
	Если ВертикальноеРастягивание = "Нет" Тогда
		Возврат ИспользованиеВертикальногоРастягивания.НеИспользовать;
	ИначеЕсли ВертикальноеРастягивание = "Использовать" Тогда
		Возврат ИспользованиеВертикальногоРастягивания.Использовать;
	Иначе
		Возврат ИспользованиеВертикальногоРастягивания.Доступно;
	КонецЕсли;
КонецФункции

Функция ПолучитьСостояниеГруппировкиЭлемента(Группировка)
	Если Группировка = "Горизонтальная" Тогда
		Возврат ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	Иначе
		Возврат ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	КонецЕсли;
КонецФункции

Процедура УстановитьСвойстваЭлементу(Элемент, Свойства)
	СвойстваСтруктура = ЕслиСтруктураНеопределеноТоНовая(Свойства);
	Для Каждого Свойство Из СвойстваСтруктура Цикл
		Попытка
			Элемент[Свойство.Ключ] = Свойство.Значение;
		Исключение
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Процедура УстановитьСобытияЭлементу(Элемент, События)
	СобытияСтруктура = ЕслиСтруктураНеопределеноТоНовая(События);
	Для Каждого Событие Из СобытияСтруктура Цикл
		Попытка
			Элемент.УстановитьДействие(Событие.Ключ, Событие.Значение);
		Исключение
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Функция СоздатьЭлементФормы(Форма, НовыйЭлемент)
	Если ТипЗнч(НовыйЭлемент) = Тип("Строка") Тогда
		Возврат Форма.Элементы.Добавить(НовыйЭлемент, Тип("ГруппаФормы"));
	Иначе
		Попытка
			Возврат Форма.Элементы.Добавить(НовыйЭлемент.Имя, НовыйЭлемент.Тип);
		Исключение
			Возврат Форма.Элементы.Добавить(НовыйЭлемент.Имя, Тип("ГруппаФормы"));
		КонецПопытки;
	КонецЕсли;
КонецФункции

Функция СздПоле(Форма, Имя, ИмяРодителя, ТипПоля = "ПолеФормы", ТипЗначения = Неопределено, ПутьКДанным = "")
	Возврат СоздатьЭлементФормы(Форма, Новый Структура("Имя, Тип", Имя, Тип(ТипПоля)));
КонецФункции

Функция СздГруппаОбычная(Форма, Имя, ИмяРодителя = "")
	Возврат СоздатьЭлементФормы(Форма, Новый Структура("Имя, Тип", Имя, Тип("ГруппаФормы")));
КонецФункции

Функция СздГруппаОбычнаяБезОтображения(Форма, Имя, ИмяРодителя = "")
	Группа = СздГруппаОбычная(Форма, Имя, ИмяРодителя);
	Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Отображение = ОтображениеОбычнойГруппы.Нет;
	Возврат Группа;
КонецФункции

Процедура СоздатьКоманду(Форма, Имя, Действие)
	Команда = Форма.Команды.Добавить(Имя);
	Команда.Действие = Действие;
КонецПроцедуры
#КонецОбласти

#Область ОбработчикКоманды
&НаСервере
Процедура ВыгрузитьНаСервере()
	ПараметрыВыгрузки = Новый Структура;
	ПараметрыВыгрузки.Вставить("Сервер", Сервер);
	ПараметрыВыгрузки.Вставить("Порт", Порт);
	ПараметрыВыгрузки.Вставить("Пользователь", Пользователь);
	ПараметрыВыгрузки.Вставить("Пароль", Пароль);
	ПараметрыВыгрузки.Вставить("ПутьНаСервере", ПутьНаСервере);
	РеквизитФормыВЗначение(ПараметрыВыгрузки, "ПараметрыВыгрузки");
	Объект.ВыгрузитьНаХостинг(Сервер, Порт, Пользователь, Пароль, ПутьНаСервере);
КонецПроцедуры

&НаКлиенте
Процедура Выгрузить(Команда)
	ОбработкаОповещения = Новый ОписаниеОповещения("ПослеВыгрузки", ЭтотОбъект);
	ПоказатьВопрос(ОбработкаОповещения, "Начать выгрузку на хостинг?", РежимДиалогаВопрос.ДаНет);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыгрузки(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		Оповестить("error", "Начинаю выгрузку...");
		ВыгрузитьНаСервере();
		Оповестить("error", "Выгрузка завершена!");
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#Область ИнициализацияФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	СоздатьРеквизитыФормы();
	СоздатьЭлементыФормы();
КонецПроцедуры

Процедура СоздатьРеквизитыФормы()
	МассивРеквизитов = Новый Массив;
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Сервер", Новый ОписаниеТипов("Строка"), "77.222.40.200"));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Порт", Новый ОписаниеТипов("Число"), 21));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Пользователь", Новый ОписаниеТипов("Строка"), "antonilyas"));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("Пароль", Новый ОписаниеТипов("Строка"), ""));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("ПутьНаСервере", Новый ОписаниеТипов("Строка"), "/vitrina"));
	МассивРеквизитов.Добавить(Новый РеквизитФормы("РежимОтладки", Новый ОписаниеТипов("Булево"), Ложь));
	Для Каждого Реквизит Из МассивРеквизитов Цикл
		ДобавитьРеквизит(Реквизит);
	КонецЦикла;
КонецПроцедуры

Процедура СоздатьЭлементыФормы()
	СоздатьКоманду(ЭтотОбъект, "ВыгрузитьКоманда", "Выгрузить");
	ГруппаКорень = СздГруппаОбычная(ЭтотОбъект, "ГруппаКорень");
	ГруппаКорень.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаКорень.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаФтп = СздГруппаОбычная(ЭтотОбъект, "ГруппаФтп", "ГруппаКорень");
	ГруппаФтп.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФтп.Заголовок = "Настройки FTP";
	ПолеСервер = СздПоле(ЭтотОбъект, "Сервер", "ГруппаФтп");
	ПолеСервер.Заголовок = "Сервер";
	ПолеСервер.ПутьКДанным = "Сервер";
	ПолеПорт = СздПоле(ЭтотОбъект, "Порт", "ГруппаФтп");
	ПолеПорт.Заголовок = "Порт";
	ПолеПорт.ПутьКДанным = "Порт";
	ПолеПользователь = СздПоле(ЭтотОбъект, "Пользователь", "ГруппаФтп");
	ПолеПользователь.Заголовок = "Пользователь";
	ПолеПользователь.ПутьКДанным = "Пользователь";
	ПолеПароль = СздПоле(ЭтотОбъект, "Пароль", "ГруппаФтп");
	ПолеПароль.Заголовок = "Пароль";
	ПолеПароль.ПутьКДанным = "Пароль";
	ПолеПароль.РежимПароля = РежимПароля.ВводПароля;
	ПолеПуть = СздПоле(ЭтотОбъект, "ПутьНаСервере", "ГруппаФтп");
	ПолеПуть.Заголовок = "Путь на сервере";
	ПолеПуть.ПутьКДанным = "ПутьНаСервере";
	ПолеРежим = СздПоле(ЭтотОбъект, "РежимОтладки", "ГруппаФтп");
	ПолеРежим.Заголовок = "Режим отладки";
	ПолеРежим.ПутьКДанным = "РежимОтладки";
	ГруппаДействия = СздГруппаОбычная(ЭтотОбъект, "ГруппаДействия", "ГруппаКорень");
	ГруппаДействия.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаДействия.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	Кнопка = СздПоле(ЭтотОбъект, "КнопкаВыгрузить", "ГруппаДействия");
	Кнопка.Заголовок = "Выгрузить каталог на хостинг";
	Кнопка.ИмяКоманды = "ВыгрузитьКоманда";
	Кнопка.Вид = ВидПоляФормы.КнопкаФормы;
КонецПроцедуры
#КонецОбласти