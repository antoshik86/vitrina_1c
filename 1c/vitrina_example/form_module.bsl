// Модуль формы внешней обработки "ВыгрузкаВитриныНаХостинг_DFI"
// Форма и реквизиты создаются полностью через DFI — ничего ручного!
// Требуется общий модуль "ДФИ" (библиотека Динамическое Формирование Интерфейса)
// https://github.com/KotovDima1C/DFI

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    // 1. Создаём реквизиты динамически
    СоздатьРеквизитыФормы();

    // 2. Значения по умолчанию
    Сервер = "77.222.40.200";
    Порт = 21;
    Пользователь = "antonilyas";
    ПутьНаСервере = "/public_html";

    // 3. Создаём элементы формы через DFI
    СоздатьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура СоздатьРеквизитыФормы()

    МассивДобавления = Новый Массив;

    р = Новый РеквизитФормы("Сервер", Новый ОписаниеТипов("Строка"));
    МассивДобавления.Добавить(р);

    р = Новый РеквизитФормы("Порт", Новый ОписаниеТипов("Число"));
    МассивДобавления.Добавить(р);

    р = Новый РеквизитФормы("Пользователь", Новый ОписаниеТипов("Строка"));
    МассивДобавления.Добавить(р);

    р = Новый РеквизитФормы("Пароль", Новый ОписаниеТипов("Строка"));
    МассивДобавления.Добавить(р);

    р = Новый РеквизитФормы("ПутьНаСервере", Новый ОписаниеТипов("Строка"));
    МассивДобавления.Добавить(р);

    ИзменитьРеквизиты(МассивДобавления);

КонецПроцедуры

&НаСервере
Процедура СоздатьЭлементыФормы()

    Родитель = Элементы;

    // Заголовок
    ДФИ.СздПоле(ЭтотОбъект, "Заголовок", Родитель, "Выгрузка каталога товаров на сайт витрины", 0, "",
        Новый Структура("Вид, Заголовок, РастягиватьПоГоризонтали, Высота",
            ВидПоляФормы.ПолеНадписи, "Выгрузка каталога товаров на сайт витрины", ИСТИНА, 3));

    // Группа FTP
    ГруппаFTP = ДФИ.СздГруппаОбычная(ЭтотОбъект, "ГруппаFTP", Родитель, "Настройки FTP", 1, 1, 0);

    ДФИ.СздПоле(ЭтотОбъект, "ПолеСервер", ГруппаFTP, "Сервер", 1, "Сервер");
    ДФИ.СздПоле(ЭтотОбъект, "ПолеПорт", ГруппаFTP, "Порт", 1, "Порт", Новый Структура("Ширина", 8));
    ДФИ.СздПоле(ЭтотОбъект, "ПолеПользователь", ГруппаFTP, "Пользователь", 1, "Пользователь");
    ДФИ.СздПоле(ЭтотОбъект, "ПолеПароль", ГруппаFTP, "Пароль", 1, "Пароль",
        Новый Структура("РежимПароля", ИСТИНА));
    ДФИ.СздПоле(ЭтотОбъект, "ПолеПуть", ГруппаFTP, "Путь на сервере", 1, "ПутьНаСервере");

    // Разделитель
    ДФИ.СздГруппаОбычнаяБезОтображения(ЭтотОбъект, "Разделитель", Родитель, 0, 0, 0,
        Новый Структура("Высота", 1));

    // Кнопка
    ДФИ.СоздатьКоманду(ЭтотОбъект, "Выгрузить", "Выгрузить каталог на хостинг", "Выгрузить");
    ДФИ.СздПоле(ЭтотОбъект, "КнопкаВыгрузить", Родитель, "", 0, "",
        Новый Структура("Вид, Заголовок, ИмяКоманды, РастягиватьПоГоризонтали",
            ВидПоляФормы.КнопкаФормы, "Выгрузить каталог на хостинг", "Выгрузить", ИСТИНА));

КонецПроцедуры

// ===== ОБРАБОТЧИКИ =====

&НаКлиенте
Процедура Выгрузить(Команда)

    Если ПустаяСтрока(Сервер) Или ПустаяСтрока(Пользователь) Тогда
        ПоказатьПредупреждение(, "Заполните настройки FTP");
        Возврат;
    КонецЕсли;

    Ответ = Вопрос("Выгрузить на сервер " + Сервер + "?",
                    РежимДиалогаВопрос.ДаНет);
    Если Ответ <> КодВозвратаДиалога.Да Тогда Возврат КонецЕсли;

    ВыгрузитьНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьНаСервере()

    Обработка = РеквизитФормыВЗначение("Объект");
    Попытка
        Обработка.ВыгрузитьНаХостинг(Сервер, Порт, Пользователь, Пароль, ПутьНаСервере);
        ПоказатьПредупреждение(, "Выгрузка завершена!");
    Исключение
        ПоказатьПредупреждение(, "Ошибка: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры
