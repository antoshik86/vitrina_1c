// vitrina_1c v3.1 — Выгрузка каталога товаров на хостинг
// https://github.com/antoshik86/vitrina_1c

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Объект.Вставить("Сервер", "77.222.40.200");
	Объект.Вставить("Порт", 21);
	Объект.Вставить("Пользователь", "antonilyas");
	Объект.Вставить("Пароль", "");
	Объект.Вставить("ПутьНаСервере", "/vitrina");
	Объект.Вставить("РежимОтладки", Ложь);
	КомандаВыгрузить = Команды.Добавить("ВыгрузитьКоманда");
	КомандаВыгрузить.Действие = "Выгрузить";
	ГруппаКорень = Элементы.Добавить("ГруппаКорень", Тип("ГруппаФормы"));
	ГруппаКорень.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаКорень.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаФтп = Элементы.Добавить("ГруппаФтп", Тип("ГруппаФормы"), ГруппаКорень);
	ГруппаФтп.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФтп.Заголовок = "Настройки FTP";
	ПолеСервер = Элементы.Добавить("Сервер", Тип("ПолеФормы"), ГруппаФтп);
	ПолеСервер.Заголовок = "Сервер";
	ПолеСервер.ПутьКДанным = "Объект.Сервер";
	ПолеПорт = Элементы.Добавить("Порт", Тип("ПолеФормы"), ГруппаФтп);
	ПолеПорт.Заголовок = "Порт";
	ПолеПорт.ПутьКДанным = "Объект.Порт";
	ПолеПользователь = Элементы.Добавить("Пользователь", Тип("ПолеФормы"), ГруппаФтп);
	ПолеПользователь.Заголовок = "Пользователь";
	ПолеПользователь.ПутьКДанным = "Объект.Пользователь";
	ПолеПароль = Элементы.Добавить("Пароль", Тип("ПолеФормы"), ГруппаФтп);
	ПолеПароль.Заголовок = "Пароль";
	ПолеПароль.ПутьКДанным = "Объект.Пароль";
	ПолеПуть = Элементы.Добавить("ПутьНаСервере", Тип("ПолеФормы"), ГруппаФтп);
	ПолеПуть.Заголовок = "Путь на сервере";
	ПолеПуть.ПутьКДанным = "Объект.ПутьНаСервере";
	ПолеРежим = Элементы.Добавить("РежимОтладки", Тип("ПолеФормы"), ГруппаФтп);
	ПолеРежим.Заголовок = "Режим отладки";
	ПолеРежим.ПутьКДанным = "Объект.РежимОтладки";
	ГруппаКнопки = Элементы.Добавить("ГруппаКнопки", Тип("ГруппаФормы"), ГруппаКорень);
	ГруппаКнопки.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаКнопки.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	Кнопка = Элементы.Добавить("КнопкаВыгрузить", Тип("ПолеФормы"), ГруппаКнопки);
	Кнопка.Вид = ВидПоляФормы.КнопкаФормы;
	Кнопка.Заголовок = "Выгрузить каталог на хостинг";
	Кнопка.ИмяКоманды = "ВыгрузитьКоманда";
КонецПроцедуры

&НаСервере
Процедура ВыгрузитьНаСервере()
	Объект.ВыгрузитьНаХостинг(Объект.Сервер, Объект.Порт, Объект.Пользователь, Объект.Пароль, Объект.ПутьНаСервере);
КонецПроцедуры

&НаКлиенте
Процедура Выгрузить(Команда)
	ОбработкаОповещения = Новый ОписаниеОповещения("ПослеВыгрузки", ЭтотОбъект);
	ПоказатьВопрос(ОбработкаОповещения, "Начать выгрузку на хостинг?", РежимДиалогаВопрос.ДаНет);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыгрузки(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		Оповестить("error", "Начинаю выгрузку...");
		ВыгрузитьНаСервере();
		Оповестить("error", "Выгрузка завершена!");
	КонецЕсли;
КонецПроцедуры