// Модуль формы внешней обработки "ВыгрузкаВитриныНаХостинг_DFI"
// Форма и реквизиты создаются полностью через DFI — ничего ручного!

&НаСервере
Процедура СоздатьРеквизитыФормы(Форма)

    МассивДобавления = Новый Массив;

    р = Новый РеквизитФормы("Сервер", Новый ОписаниеТипов("Строка"));
    МассивДобавления.Добавить(р);

    р = Новый РеквизитФормы("Порт", Новый ОписаниеТипов("Число"));
    МассивДобавления.Добавить(р);

    р = Новый РеквизитФормы("Пользователь", Новый ОписаниеТипов("Строка"));
    МассивДобавления.Добавить(р);

    р = Новый РеквизитФормы("Пароль", Новый ОписаниеТипов("Строка"));
    МассивДобавления.Добавить(р);

    р = Новый РеквизитФормы("ПутьНаСервере", Новый ОписаниеТипов("Строка"));
    МассивДобавления.Добавить(р);

    Форма.ИзменитьРеквизиты(МассивДобавления);

КонецПроцедуры

&НаСервере
Процедура СоздатьЭлементыФормы(Форма)

    Родитель = Форма.Элементы;

    // Заголовок
    ДФИ.СздПоле(Форма, "Заголовок", Родитель, "Выгрузка каталога товаров на сайт витрины", 0, "",
        Новый Структура("Вид, Заголовок, РастягиватьПоГоризонтали, Высота",
            ВидПоляФормы.ПолеНадписи, "Выгрузка каталога товаров на сайт витрины", ИСТИНА, 3));

    // Группа FTP
    ГруппаFTP = ДФИ.СздГруппаОбычная(Форма, "ГруппаFTP", Родитель, "Настройки FTP", 1, 1, 0);

    ДФИ.СздПоле(Форма, "ПолеСервер", ГруппаFTP, "Сервер", 1, "Сервер");
    ДФИ.СздПоле(Форма, "ПолеПорт", ГруппаFTP, "Порт", 1, "Порт", Новый Структура("Ширина", 8));
    ДФИ.СздПоле(Форма, "ПолеПользователь", ГруппаFTP, "Пользователь", 1, "Пользователь");
    ДФИ.СздПоле(Форма, "ПолеПароль", ГруппаFTP, "Пароль", 1, "Пароль",
        Новый Структура("РежимПароля", ИСТИНА));
    ДФИ.СздПоле(Форма, "ПолеПуть", ГруппаFTP, "Путь на сервере", 1, "ПутьНаСервере");

    // Разделитель
    ДФИ.СздГруппаОбычнаяБезОтображения(Форма, "Разделитель", Родитель, 0, 0, 0,
        Новый Структура("Высота", 1));

    // Кнопка
    ДФИ.СоздатьКоманду(Форма, "Выгрузить", "Выгрузить каталог на хостинг", "Выгрузить");
    ДФИ.СздПоле(Форма, "КнопкаВыгрузить", Родитель, "", 0, "",
        Новый Структура("Вид, Заголовок, ИмяКоманды, РастягиватьПоГоризонтали",
            ВидПоляФормы.КнопкаФормы, "Выгрузить каталог на хостинг", "Выгрузить", ИСТИНА));

КонецПроцедуры

// ===== ОБРАБОТЧИКИ =====

&НаКлиенте
Процедура Выгрузить(Команда)

    Если ПустаяСтрока(Сервер) Или ПустаяСтрока(Пользователь) Тогда
        ПоказатьПредупреждение(, "Заполните настройки FTP (Сервер, Пользователь, Пароль)");
        Возврат;
    КонецЕсли;

    Ответ = Вопрос("Выгрузить " + ПутьНаСервере + " на " + Сервер + "?",
                    РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);
    Если Ответ <> КодВозвратаДиалога.Да Тогда Возврат КонецЕсли;

    Оповещение = Новый ОписаниеОповещения("ПослеВыгрузки", ЭтотОбъект);
    ВыгрузитьНаСервере(Оповещение, Сервер, Порт, Пользователь, Пароль, ПутьНаСервере);

КонецПроцедуры

&НаКлиенте
Процедура ПослеВыгрузки(Результат, ДополнительныеПараметры) Экспорт
    Если Результат = Неопределено Тогда
        ПоказатьПредупреждение(, "Выгрузка завершена!");
    Иначе
        ПоказатьПредупреждение(, "Ошибка: " + Результат.Описание);
    КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ВыгрузитьНаСервере(Оповещение, знСервер, знПорт, знПользователь, знПароль, знПуть)

    Обработка = РеквизитФормыВЗначение("Объект");
    Попытка
        Обработка.ВыгрузитьНаХостинг(знСервер, знПорт, знПользователь, знПароль, знПуть);
        ВыполнитьОбработкуОповещения(Оповещение, Неопределено);
    Исключение
        ВыполнитьОбработкуОповещения(Оповещение, ИнформацияОбОшибке());
    КонецПопытки;

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    // 1. Создаём реквизиты динамически
    СоздатьРеквизитыФормы(Форма);

    // 2. Значения по умолчанию
    Сервер = "77.222.40.200";
    Порт = 21;
    Пользователь = "antonilyas";
    ПутьНаСервере = "/public_html";

    // 3. Создаём элементы формы через DFI
    СоздатьЭлементыФормы(Форма);

КонецПроцедуры
