// vitrina_1c test runner — автотест в пакетном режиме
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Надпись = Элементы.Добавить("Надпись", Тип("ПолеФормы"));
	Надпись.Заголовок = "Тестирование...";
	Надпись.Вид = ВидПоляФормы.ПолеНадписи;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Результат = Тестировать();
	Сообщить("TEST_RESULT: " + Результат);
	Попытка
		ЗавершитьРаботуСистемы(0);
	Исключение
		Закрыть();
	КонецПопытки;
КонецПроцедуры

&НаСервере
Функция Тестировать()
	ПутьКВитрине = ПараметрыПриложения.ПараметрЗапуска;
	Попытка
		Обработка = ВнешниеОбработки.Создать(ПутьКВитрине);
		Если Обработка = Неопределено Тогда
			Возврат "FAIL: vitrina_export.epf не загрузилась";
		КонецЕсли;
		Сведения = Обработка.СведенияОВнешнейОбработке("");
		ИмяОбработки = Сведения.Имя;
		Результат = "OK: загружена """ + ИмяОбработки + """";
		Попытка
			Обработка.ВыгрузитьНаСервере();
			Результат = Результат + ", ВыгрузитьНаСервере отработала";
		Исключение
			Результат = Результат + ", ВыгрузитьНаСервере: " + ОписаниеОшибки();
		КонецПопытки;
		Возврат Результат;
	Исключение
		Возврат "FAIL: " + ОписаниеОшибки();
	КонецПопытки;
КонецФункции
